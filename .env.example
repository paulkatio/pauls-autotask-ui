# .env.example
# Kopiere diese Datei zu .env.local und fülle die Werte ein.
# .env.local NIEMALS committen. Diese Vorlage enthält NUR Platzhalter.

# --- Auth-Modus ---
# mock  = lokaler Mock-Login (Phase 1)
# entra = Microsoft Entra ID (spätere Phase, B16)
AUTH_MODE=mock

# --- Branding (optional) ---
# Eigener Firmen-/Markenname für Sidebar, Login, Web-App-Manifest und die
# Mail-Signatur. NEXT_PUBLIC_* → zur Build-Zeit eingebettet. Ohne Angabe: "Acme GmbH".
NEXT_PUBLIC_ORG_NAME=

# --- Autotask REST API (Sandbox) ---
# Base-URL der Zone, z. B. https://webservicesX.autotask.net/ATServicesRest/V1.0
AUTOTASK_BASE_URL=
AUTOTASK_API_USERNAME=
# Hinweis: Secret kann Sonderzeichen ($ ~ * # @) enthalten. In .env.local in
# EINFACHE Anführungszeichen setzen, sonst kann '$' eine Variablen-Expansion
# auslösen und Teile des Secrets verschlucken. Beispiel: AUTOTASK_API_SECRET='...'
AUTOTASK_API_SECRET=
AUTOTASK_INTEGRATION_CODE=
# Optional: Basis der Autotask-WEBoberfläche für „In Autotask öffnen"-Links.
# Ohne Angabe wird sie aus AUTOTASK_BASE_URL abgeleitet (webservicesN -> wwN),
# z. B. https://ww18.autotask.net. Nur setzen, wenn die Ableitung nicht passt.
AUTOTASK_WEB_URL=

# --- Autotask API-User-Pool (Phase B, OPTIONAL) ---
# Mehrere API-User = Ausfallsicherheit + mehr Durchsatz (jeder Login hat ein EIGENES
# 3-Thread-Budget pro Objekt, sofern eigener Integration-Code). Member 1 = die
# unsuffixierten Vars oben (Primär, EINZIGER Schreib-User). Member 2/3 optional.
# Secrets ebenfalls in EINFACHE Anführungszeichen (Sonderzeichen).
AUTOTASK_API_USERNAME_2=
AUTOTASK_API_SECRET_2=
AUTOTASK_INTEGRATION_CODE_2=
AUTOTASK_API_USERNAME_3=
AUTOTASK_API_SECRET_3=
AUTOTASK_INTEGRATION_CODE_3=
# Schalter: leer/0 = AUS (nur Member 1, Verhalten exakt wie ohne Pool). 1 = AN
# (Reads über gesunde Member verteilt, Gate-Key member:entity, Writes strikt Member 1).
# Der Pool wird nur WIRKLICH aktiv, wenn die Config valide ist (sonst Warnung + Fallback
# auf Single-Member): mind. 2 Member, genau ein Primär (Member 1), UND eindeutige
# Integration-Codes + UserNames. WICHTIG:
#  - Jeder Member braucht einen EIGENEN Integration-Code (doppelte bringen kein Extra-
#    Budget; ein UNGÜLTIGER Code kann einen tenant-weiten 401-Lockout auslösen → erst AN
#    schalten, wenn alle Member in Autotask aktiv/gültig sind).
#  - Auf Vercel (mehrere Instanzen) NUR mit gesetztem Upstash (UPSTASH_REDIS_REST_*) AN
#    schalten — sonst koordiniert nur der Prozess-Limiter und die „Thread Threshold"-
#    Alerts kommen zurück.
AUTOTASK_POOL_ENABLED=
# Optional: 1 = loggt die Member-Auswahl je Call ([pool] read Tickets -> member 2).
# Nur zur Diagnose/Verifikation, sonst leer lassen.
AUTOTASK_POOL_DEBUG=

# --- Microsoft Entra ID (B16a; nur nötig wenn AUTH_MODE=entra) ---
# WICHTIG: Der Provider wird in lib/auth/authjs.ts EXPLIZIT aus diesen ENTRA_*-
# Namen konfiguriert (NICHT die Auth.js-Defaults AUTH_MICROSOFT_ENTRA_ID_*).
ENTRA_CLIENT_ID=                     # Application (client) ID der Entra-App
ENTRA_CLIENT_SECRET=                 # Client-Secret-Wert
ENTRA_TENANT_ID=                     # Directory (tenant) ID -> tenant-spezifischer Issuer
# AUTH_SECRET: zufälliger Wert, z. B. `openssl rand -base64 32` (JWT-Signatur)
AUTH_SECRET=
# Kanonische App-URL (Redirects/Callback). Lokal so lassen; Prod = https://<DOMAIN>
AUTH_URL=http://localhost:3000
# Hinter Caddy/Non-Vercel nötig, damit Auth.js den Proxy-Host akzeptiert:
AUTH_TRUST_HOST=true
# Redirect-URI in der Entra-App: <AUTH_URL>/api/auth/callback/microsoft-entra-id
# Scope: openid profile email User.Read (User.Read = Profilfoto via Graph).
#
# NUR Sandbox: der Sandbox-Refresh hängt Resource-Mails ein +psasandbox-Tag an;
# ENTRA_EMAIL_LOOSE_MATCH=1 erlaubt den toleranten E-Mail->Resource-Abgleich.
# In PRODUKTION weglassen (dann streng exakter Abgleich).
ENTRA_EMAIL_LOOSE_MATCH=

# --- Vertriebsbereich (Rechnungen/Verträge/Angebote) – Zugriffs-Allowlist ---
# Der Bereich /vertrieb ist NUR für die hier gelisteten Autotask-Resource-IDs
# sichtbar/erreichbar (kommagetrennt). FAIL-CLOSED: leer/fehlend ⇒ NIEMAND sieht ihn.
# Es sind die PROD-Resource-IDs der berechtigten Personen einzutragen (NICHT die
# Sandbox-IDs – dort andere). Server-only, niemals NEXT_PUBLIC_. Beispiel:
# SALES_ALLOWED_RESOURCE_IDS=29682886,29682903
SALES_ALLOWED_RESOURCE_IDS=

# --- Kundenmail-Versand (B17: app-eigene Kundenmail via Resend) ---
# Resend ist der EINZIGE Versandweg (kein Autotask-Workflow/UDF mehr, kein Umschalter).
# Resend API-Key (https://resend.com -> API Keys). Server-only, nie ins Client-Bundle.
RESEND_API_KEY=
# Absender (verifizierte Resend-Domain), z. B.: Acme Service Desk <service@example.com>
RESEND_FROM=
# Autotask-Eingangspostfach = Reply-To, damit Kundenantworten als TicketNote zurücklaufen
AUTOTASK_INBOUND_MAILBOX=

# --- Globaler Autotask-Thread-Limiter (optional, Upstash Redis) ---
# Autotask begrenzt auf 3 gleichzeitige Requests pro Objekt-Endpoint PRO INTEGRATION
# (global, nicht pro Prozess). Auf Vercel laufen mehrere Instanzen → der In-Process-
# Limiter kann das nicht koordinieren. Mit diesen zwei Werten nutzt der Client einen
# INSTANZENÜBERGREIFENDEN Semaphore über Upstash Redis (serverless, HTTP).
# Sind beide LEER, fällt der Client automatisch auf den In-Process-Limiter zurück
# (Verhalten exakt wie ohne Upstash – kein Bruch).
# Anlegen: Vercel → Storage/Marketplace → Upstash → Redis-DB (setzt diese Vars
# automatisch), ODER upstash.com → Create Database → Redis → REST-Werte kopieren.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
