# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — Secrets ignorieren, Platzhalter-Vorlage versionieren
.env
.env.local
.env.*.local
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# lokale Verifikations-Screenshots (nicht versioniert)
/docs/visual-refresh/

# Playwright-MCP-Artefakte (lokale Browser-Verifikation, nicht versioniert)
/.playwright-mcp/

# Playwright-E2E (Artefakte + Auth-State, nicht versioniert)
/test-results/
/playwright-report/
/e2e/.auth/

# Verifikations-Screenshots im Repo-Root (nicht committen)
/*.png

# Logo-Backups in public/ nicht versionieren
/public/*_old.png

# Claude-Code-Arbeitsdateien (nur lokal, nicht ins öffentliche Repo)
/CLAUDE.md
/.claude/
